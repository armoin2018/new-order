{
  "name": "new-order",
  "private": true,
  "version": "0.1.0",
  "description": "New Order: Global Simulation Engine — A turn-based geopolitical simulation game",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "docs": "typedoc",
    "docs:open": "typedoc && open docs/api/index.html",
    "play": "bash scripts/install-and-launch.sh",
    "play:build": "bash scripts/install-and-launch.sh --build",
    "server:dev": "tsx watch server/index.ts",
    "server:start": "tsx server/index.ts",
    "server:typecheck": "tsc --noEmit -p tsconfig.server.json",
    "test:server": "vitest run --config vitest.server.config.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.0.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "ajv": "^8.18.0",
    "fastify": "^5.8.1",
    "immer": "^11.1.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "uuid": "^13.0.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.3",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.21.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^15.15.0",
    "happy-dom": "^20.8.3",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.5.0",
    "tsx": "^4.21.0",
    "typescript": "~5.7.0",
    "typescript-eslint": "^8.24.0",
    "vite": "^6.2.0",
    "vitest": "^4.0.18"
  }
}
